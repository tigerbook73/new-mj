{
  "name": "new-mj",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint && eslint tools",
    "lint:fix": "eslint --fix .",
    "test": "turbo run test && node --test tools/*.test.ts",
    "test:e2e": "turbo run test:e2e",
    "verify": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm build && pnpm test && pnpm test:e2e",
    "check:deps": "node tools/check-deps.ts",
    "cli:play": "node packages/core/src/cli.ts play",
    "fuzz": "node packages/core/src/cli.ts fuzz"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "prettier": "^3.9.5",
    "supabase": "^2.109.1",
    "tsup": "^8.5.1",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
