# Committed to git — never put real secrets here; use .env.development.local for those. See docs/contracts/session-mechanics.md §10 for what each var gates.

# ── apps/server ──────────────────────────────────────────────────────
PORT=3000
# Gates the debug:omniscientView / debug:replayOmniscientView channels
# (decisions.md D19). Never set true in a shipped deployment.
ALLOW_DEBUG_OMNISCIENT=false

# Prisma's direct Postgres connection (apps/server/prisma/schema.prisma).
# Local Supabase (`pnpm exec supabase start`) prints this; default local
# port is 54322, not the usual 5432.
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Real Supabase Auth verification (decisions.md phase 5 entry). If either is
# unset, apps/server falls back to the JWT_SECRET dev path (decisions.md
# D16, default "dev-only-insecure-secret") — set both together, never just
# one.
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ── apps/web ─────────────────────────────────────────────────────────
# Read by Vite at build/dev time (import.meta.env.VITE_*), not by
# apps/server. Same local Supabase instance as above unless you're pointing
# web at a different deployment than server.
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
