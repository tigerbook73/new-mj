# Copy to .env (gitignored) and fill in real values. See
# docs/contracts/session-mechanics.md §10 for what each of these gates.

# ── apps/server ──────────────────────────────────────────────────────
# Dev-only fallback if unset: "dev-only-insecure-secret" (decisions.md D16).
# Must be set to a real value in any shared/production deployment.
JWT_SECRET=
PORT=3000
# Gates the debug:omniscientView / debug:replayOmniscientView channels
# (decisions.md D19). Never set true in a shipped deployment.
ALLOW_DEBUG_OMNISCIENT=false

# Prisma's direct Postgres connection (apps/server/prisma/schema.prisma).
# Local Supabase (`npx supabase start`) prints this; default local port is
# 54322, not the usual 5432.
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Real Supabase Auth verification (decisions.md phase 5 entry). If either is
# unset, apps/server falls back to the JWT_SECRET dev path above — set both
# together, never just one.
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_KEY=

# ── apps/web ─────────────────────────────────────────────────────────
# Read by Vite at build/dev time (import.meta.env.VITE_*), not by
# apps/server. Same local Supabase instance as above unless you're pointing
# web at a different deployment than server.
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=
